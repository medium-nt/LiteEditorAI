# Скопируй в .env и заполни. Файл .env в git НЕ коммитится (см. .gitignore).

# --- Обязательно ---
# Домен релея (DNS A-запись должна указывать на IP этого сервера):
RELAY_DOMAIN=relay.example.com
# Email для Let's Encrypt (уведомления о сертификате):
RELAY_ACME_EMAIL=you@example.com
# Ключ HMAC-подписи токенов сессий — сгенерируй СВОЙ случайный:
#   openssl rand -hex 32
RELAY_SECRET=changeme-сгенерируй-свой-секрет

# --- Необязательно (есть безопасные дефолты в compose.yml) ---
# RELAY_REQUIRE_PAIRING=1     # обязательное одобрение устройства на ПК (рекомендуется для личного сервера)
# RELAY_MIN_PASSWORD=8        # мин. длина пароля при регистрации
# RELAY_TOKEN_TTL=2592000     # TTL сессии, сек (30 суток)
# RELAY_LOGIN_MAX_FAILS=5     # неудачных входов до временной блокировки (per-login)
# RELAY_LOGIN_LOCKOUT=900     # длительность блокировки, сек
# RELAY_REG_MAX_PER_IP=10     # регистраций с одного IP за сутки
# RELAY_MAX_CONN_PER_IP=40    # одновременных WS-соединений с одного IP
