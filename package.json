{
  "name": "liteeditor-ai",
  "version": "1.1.70-alpha",
  "description": "Lightweight editor for working with AI coding agents in the terminal",
  "main": "main.js",
  "author": "Максим Кузьминский <i@m-letto.ru>",
  "license": "Apache-2.0",
  "homepage": "https://github.com/DanielLetto2020/LiteEditorAI",
  "repository": {
    "type": "git",
    "url": "https://github.com/DanielLetto2020/LiteEditorAI.git"
  },
  "scripts": {
    "test": "node test/safe-name.test.js && node test/sgrline.test.js && node test/shell.test.js",
    "build": "node build.js",
    "start": "node build.js && electron --no-sandbox --class=LiteEditorAI .",
    "watch": "node build.js --watch",
    "rebuild": "electron-rebuild -f -o node-pty",
    "postinstall": "electron-rebuild -f -o node-pty || echo 'node-pty rebuild skipped — run: npm run rebuild'",
    "gen-icons": "node scripts/gen-icons.js",
    "install-desktop": "node scripts/install-desktop.js",
    "dist:linux": "node build.js && electron-builder --linux deb",
    "dist:win": "node build.js && electron-builder --win zip",
    "dist:mac": "node build.js && electron-builder --mac",
    "release": "node scripts/release.js"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.3",
    "@codemirror/commands": "^6.7.1",
    "@codemirror/lang-css": "^6.3.0",
    "@codemirror/lang-html": "^6.4.9",
    "@codemirror/lang-javascript": "^6.2.2",
    "@codemirror/lang-json": "^6.0.1",
    "@codemirror/lang-markdown": "^6.3.1",
    "@codemirror/lang-python": "^6.1.6",
    "@codemirror/lang-sql": "^6.10.0",
    "@codemirror/language": "^6.10.6",
    "@codemirror/language-data": "^6.5.2",
    "@codemirror/merge": "^6.12.2",
    "@codemirror/search": "^6.7.0",
    "@codemirror/state": "^6.5.0",
    "@codemirror/theme-one-dark": "^6.1.2",
    "@codemirror/view": "^6.35.0",
    "@noble/hashes": "^2.2.0",
    "@replit/codemirror-indentation-markers": "^6.5.3",
    "@replit/codemirror-minimap": "^0.5.2",
    "@xterm/addon-canvas": "^0.7.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-serialize": "^0.13.0",
    "@xterm/addon-unicode11": "^0.9.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/headless": "^5.5.0",
    "@xterm/xterm": "^5.5.0",
    "basic-ftp": "^6.0.1",
    "chart.js": "^4.5.1",
    "highlight.js": "^11.11.1",
    "js-yaml": "^4.2.0",
    "kdbxweb": "^2.1.1",
    "marked": "^18.0.4",
    "mathjax-full": "^3.2.1",
    "mysql2": "^3.22.4",
    "node-pty": "^1.0.0",
    "pg": "^8.21.0",
    "sql.js": "^1.14.1",
    "ssh2": "^1.17.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "electron": "^42.4.0",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.28.1",
    "sharp": "^0.33.5"
  },
  "overrides": {
    "@electron/get": {
      "undici": "^7.28.0"
    },
    "node-gyp": {
      "undici": "^6.27.0"
    },
    "@xmldom/xmldom": "0.8.13"
  },
  "build": {
    "appId": "com.mletto.liteeditorai",
    "productName": "LiteEditorAI",
    "directories": {
      "output": "dist-release",
      "buildResources": "assets"
    },
    "npmRebuild": false,
    "afterPack": "scripts/afterPack-mac.js",
    "asarUnpack": [
      "**/node_modules/node-pty/**",
      "**/node_modules/sql.js/dist/sql-wasm.wasm"
    ],
    "files": [
      "main.js",
      "remote.js",
      "preload.js",
      "logger.js",
      "errledger.js",
      "lib/**",
      "package.json",
      "renderer/index.html",
      "renderer/module.html",
      "renderer/styles.css",
      "renderer/dist/**",
      "assets/icon.png",
      "assets/icon.svg",
      "module-kit/GUIDE.md",
      "module-kit/ai/**",
      "!**/*.pdb"
    ],
    "linux": {
      "target": [
        "deb"
      ],
      "category": "Development",
      "icon": "assets/icon.png",
      "maintainer": "Максим Кузьминский <i@m-letto.ru>",
      "executableArgs": [
        "--no-sandbox"
      ],
      "desktop": {
        "entry": {
          "StartupWMClass": "liteeditor-ai"
        }
      }
    },
    "win": {
      "target": [
        "zip"
      ],
      "icon": "assets/icon.png",
      "signAndEditExecutable": true,
      "asar": false
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "category": "public.app-category.developer-tools",
      "icon": "assets/icon.png",
      "identity": null,
      "entitlements": "assets/entitlements.mac.plist",
      "entitlementsInherit": "assets/entitlements.mac.plist"
    }
  }
}
