# Конфиг пульта, вшивается в APK при сборке (gitignored, скопируй в lite.properties).
# TOKEN должен совпадать с RELAY_TOKEN релея (ansible/secrets/liteeditor-relay.env)
# и с тем, что задаёт ПК-редактор (LITE_RELAY_TOKEN). ROOM — одинаковый у ПК и пульта.
RELAY_URL=wss://relay.example.com/ws
ROOM=default
TOKEN=changeme
